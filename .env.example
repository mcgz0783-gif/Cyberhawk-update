# =====================================================
# CyberSec Updates — Environment Variables
# =====================================================
# Copy this file to .env (or .env.local for local override) and fill in your values.
# NEVER commit .env to version control.

# ── Google Generative AI (Gemini) ────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
# When set, the AI chatbot uses Google Gemini 1.5 Pro.
# When NOT set, it falls back to the Anthropic Claude API
# (works automatically in the Claude.ai artifact preview).
VITE_GEMINI_API_KEY=your_google_gemini_api_key_here

# ── Site Configuration ────────────────────────────────
VITE_SITE_NAME=CyberSec Updates
VITE_SITE_URL=https://your-domain.com
